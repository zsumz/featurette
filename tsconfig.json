{
    "compilerOptions": {
        "declaration": true,
        "declarationMap": false,
        "lib": ["ES2022"],
        "allowImportingTsExtensions": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noEmit": true,
        "skipLibCheck": true,
        "sourceMap": false,
        "strict": true,
        "target": "ES2022",
        "verbatimModuleSyntax": true
    },
    "include": [
        "smoke/**/*.ts",
        "src/**/*.ts",
        "tests/**/*.ts",
        "vitest.config.ts"
    ]
}
